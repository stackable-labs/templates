{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    }
  },
  "globalEnv": [
    "VITE_EXTENSION_PORT",
    "VITE_PREVIEW_PORT"
  ]
}
