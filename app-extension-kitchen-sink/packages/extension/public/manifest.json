{
  "name": "__EXTENSION_DISPLAY_NAME__",
  "version": "1.0.0",
  "targets": ["slot.header", "slot.content", "slot.footer", "slot.footer-links"],
  "permissions": ["context:read", "data:query", "data:fetch", "actions:toast", "actions:invoke", "events:identity", "events:messaging", "events:activity", "identity:extend", "messaging:send"],
  "events": ["identity:login", "identity:logout", "identity:refresh", "messaging:postback:add_to_cart", "activity:product_view"],
  "identityClaims": ["reservation_status", "chef_rating", "chef_endorsed"],
  "allowedDomains": ["jsonplaceholder.typicode.com"],
  "settingsSchema": [
    { "identifier": "apiEndpoint", "label": "API Endpoint", "type": "text", "placeholder": "https://jsonplaceholder.typicode.com" },
    { "identifier": "apiKey", "label": "API Key", "type": "text", "secret": true, "required": true }
  ]
}
